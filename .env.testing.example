APP_ENV=testing
APP_KEY=

# Copy APP_KEY from your .env.
# PHPUnit loads this file instead of .env. DB_USERNAME must differ from .env.

DB_CONNECTION=oracle
DB_HOST=localhost
DB_PORT=1521
DB_DATABASE=XE
DB_SERVICE_NAME=XE
DB_USERNAME=laravel_test
DB_PASSWORD=password
DB_CHARSET=AL32UTF8
DB_SERVER_VERSION=21c

# DBA login used once to auto-create laravel_test if missing (local XE: usually system)
ORACLE_DBA_USERNAME=system
ORACLE_DBA_PASSWORD=
